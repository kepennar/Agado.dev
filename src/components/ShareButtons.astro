---
// ShareButtons component - social sharing buttons for blog posts
// Uses URL intent links for Twitter/LinkedIn, clipboard API for copy

interface Props {
  url: string;
  translations: {
    shareOn: string;
    copyLink: string;
    linkCopied: string;
  };
}

const { url, translations } = Astro.props;

const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
---

<div class="share-buttons">
  <span class="share-label">{translations.shareOn}</span>
  <div class="share-icons">
    <!-- LinkedIn -->
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn"
      title={`${translations.shareOn} LinkedIn`}
    >
      <svg
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path>
      </svg>
    </a>

    <!-- Copy Link -->
    <button
      class="share-btn copy-link-btn"
      title={translations.copyLink}
      data-url={url}
      data-copied-text={translations.linkCopied}
      data-default-text={translations.copyLink}
    >
      <svg
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
        ></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
        ></path>
      </svg>
      <span class="copy-link-text">{translations.copyLink}</span>
    </button>
  </div>
</div>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    margin-top: 2rem;
  }

  :global(.dark) .share-buttons {
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  .share-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: #666;
    white-space: nowrap;
  }

  :global(.dark) .share-label {
    color: #999;
  }

  .share-icons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 6px;
    color: #555;
    background: transparent;
    text-decoration: none;
    font-size: 0.85rem;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
    font-family: inherit;
  }

  .share-btn:hover {
    color: var(--color-primary, #3457a0);
    border-color: var(--color-primary, #3457a0);
    background-color: rgba(52, 87, 160, 0.05);
  }

  :global(.dark) .share-btn {
    border-color: rgba(255, 255, 255, 0.15);
    color: #aaa;
  }

  :global(.dark) .share-btn:hover {
    color: #8ab4f8;
    border-color: #8ab4f8;
    background-color: rgba(138, 180, 248, 0.08);
  }

  .copy-link-text {
    font-size: 0.85rem;
  }

  @media (max-width: 480px) {
    .share-buttons {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .copy-link-text {
      display: none;
    }
  }

  @media print {
    .share-buttons {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var btns = document.querySelectorAll(".copy-link-btn");
    btns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var url = btn.getAttribute("data-url");
        var copiedText = btn.getAttribute("data-copied-text");
        var defaultText = btn.getAttribute("data-default-text");
        var textEl = btn.querySelector(".copy-link-text");
        if (navigator.clipboard && url) {
          navigator.clipboard.writeText(url).then(function () {
            if (textEl) {
              textEl.textContent = copiedText;
              setTimeout(function () {
                textEl.textContent = defaultText;
              }, 2000);
            }
          });
        }
      });
    });
  })();
</script>
