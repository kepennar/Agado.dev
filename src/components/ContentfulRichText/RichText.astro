---
// ContentfulRichText component - renders Contentful rich text content
// Supports embedded assets, headings with IDs, paragraphs, links, etc.
// Uses Shiki for server-side syntax highlighting (no client-side JS needed)
// Images are optimized at build time using Astro's getImage API and rendered directly in HTML

import type { Document } from "@contentful/rich-text-types";
import { renderRichText } from "@/lib/rich-text-renderer";

interface Props {
  content: Document;
  class?: string;
}

const { content, class: className = "" } = Astro.props;

// Render the rich text document to HTML with pre-rendered code blocks and images
// Images are now embedded directly in the HTML for optimal performance
const { html } = await renderRichText(content);
---

<div class:list={["cms-content", className]}>
  <!-- Render HTML content with pre-rendered code blocks and optimized images -->
  <Fragment set:html={html} />
</div>

<style is:global>
  .cms-content {
    line-height: 1.7;
    font-size: 1.125rem;
    color: #333;
  }

  .dark .cms-content {
    color: #e5e5e5;
  }

  /* Headings */
  .cms-content h1,
  .cms-content h2,
  .cms-content h3,
  .cms-content h4,
  .cms-content h5,
  .cms-content h6 {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
    line-height: 1.3;
    color: #1a1a1a;
    scroll-margin-top: 5rem; /* Offset for fixed header when navigating to anchor */
  }

  .dark .cms-content h1,
  .dark .cms-content h2,
  .dark .cms-content h3,
  .dark .cms-content h4,
  .dark .cms-content h5,
  .dark .cms-content h6 {
    color: #f5f5f5;
  }

  .cms-content h1 {
    font-size: 2.5rem;
  }

  .cms-content h2 {
    font-size: 2rem;
  }

  .cms-content h3 {
    font-size: 1.75rem;
  }

  .cms-content h4 {
    font-size: 1.5rem;
  }

  .cms-content h5 {
    font-size: 1.25rem;
  }

  .cms-content h6 {
    font-size: 1.125rem;
  }

  /* Paragraphs */
  .cms-content p {
    margin-bottom: 1.5rem;
  }

  /* Images - Support both img and picture elements */
  .cms-content .rich-text-image,
  .cms-content picture {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2rem 0;
  }

  .cms-content .rich-text-image img,
  .cms-content picture img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .dark .cms-content .rich-text-image img,
  .dark .cms-content picture img {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
  }

  /* Links */
  .cms-content a {
    color: #0066cc;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  .cms-content a:hover {
    color: #0052a3;
  }

  .dark .cms-content a {
    color: #4da6ff;
  }

  .dark .cms-content a:hover {
    color: #66b3ff;
  }

  /* Lists */
  .cms-content ul,
  .cms-content ol {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .cms-content li {
    list-style-type: disc;
    margin-bottom: 0.5rem;
  }

  /* Code (inline) */
  .cms-content .rich-text-paragraph code {
    background-color: #f5f5f5;
    color: #e01e5a;
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: "Courier New", monospace;
  }

  .dark .cms-content .rich-text-paragraph code {
    background-color: #2d2d2d;
    color: #ff6b9d;
  }

  /* Shiki code blocks (.shiki is generated by Astro's Code component) */
  .cms-content .shiki {
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.95rem;
    line-height: 1.6;
    font-family: "Courier New", Courier, monospace;
    margin: 0;
  }

  .cms-content .shiki code {
    display: block;
    width: fit-content;
    min-width: 100%;
  }

  /* Scrollbar styling for code blocks */
  .cms-content .shiki::-webkit-scrollbar {
    height: 8px;
  }

  .cms-content .shiki::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  .cms-content .shiki::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3);
    border-radius: 4px;
  }

  .cms-content .shiki::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  /* Blockquotes */
  .cms-content blockquote {
    border-left: 4px solid #0066cc;
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #666;
    background-color: rgba(0, 102, 204, 0.04);
    border-radius: 0 8px 8px 0;
  }

  .dark .cms-content blockquote {
    border-left-color: #4da6ff;
    color: #d5d5d5;
    background-color: rgba(77, 166, 255, 0.06);
  }

  /* Tables */
  .cms-content table {
    display: block;
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: thin;
    border-collapse: collapse;
    margin: 2rem 0;
  }

  .cms-content th,
  .cms-content td {
    border: 1px solid #ddd;
    padding: 0.75rem;
    text-align: left;
  }

  .dark .cms-content th,
  .dark .cms-content td {
    border-color: #444;
  }

  .cms-content th {
    background-color: #f5f5f5;
    font-weight: 700;
  }

  .dark .cms-content th {
    background-color: #2d2d2d;
  }

  /* Horizontal rule */
  .cms-content hr {
    border: none;
    border-top: 2px solid #ddd;
    margin: 3rem 0;
  }

  .dark .cms-content hr {
    border-top-color: #444;
  }

  /* Error message */
  .cms-content .error {
    color: #e01e5a;
    background-color: #fff3cd;
    padding: 1rem;
    border-radius: 4px;
    border-left: 4px solid #e01e5a;
  }

  .dark .cms-content .error {
    background-color: #3d2a2a;
    color: #ff6b9d;
  }

  /* Shiki Transformer Styles */

  /* Diff highlighting */
  .cms-content .shiki .line.diff.add {
    background-color: rgba(46, 160, 67, 0.15);
  }

  .cms-content .shiki .line.diff.add::before {
    content: "+";
    color: #2ea043;
    padding-right: 0.5rem;
  }

  .cms-content .shiki .line.diff.remove {
    background-color: rgba(248, 81, 73, 0.15);
  }

  .cms-content .shiki .line.diff.remove::before {
    content: "-";
    color: #f85149;
    padding-right: 0.5rem;
  }

  /* Line highlighting */
  .cms-content .shiki .line.highlighted {
    background-color: rgba(101, 117, 133, 0.16);
  }

  /* Focus mode - dim non-focused lines */
  .cms-content .shiki.has-focused .line:not(.focused) {
    filter: blur(0.095rem);
    opacity: 0.4;
    transition:
      filter 0.35s,
      opacity 0.35s;
  }

  .cms-content .shiki.has-focused:hover .line:not(.focused) {
    filter: blur(0px);
    opacity: 1;
  }

  /* Error and warning levels */
  .cms-content .shiki .line.error {
    background-color: rgba(248, 81, 73, 0.15);
    border-left: 3px solid #f85149;
    padding-left: 0.5rem;
  }

  .cms-content .shiki .line.warning {
    background-color: rgba(187, 128, 9, 0.15);
    border-left: 3px solid #bb8009;
    padding-left: 0.5rem;
  }
</style>
