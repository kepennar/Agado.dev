---
// KeyDifferentiators component - Stacked quote + detailed bio section
// Uses CMS slogan as prominent quote, CMS abstract as detailed content

import type { Abstract, Slogan } from "@/lib/contentful.types";
import RichText from "./ContentfulRichText/RichText.astro";

interface Props {
  slogan?: Slogan;
  abstract?: Abstract;
  translations: {
    keyDifferentiators: string;
    differentiatorQuote2: string;
  };
}

const { slogan, abstract, translations } = Astro.props;
---

<section class="py-16 sm:py-20 border-y border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#0a1628]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <span class="section-label">{translations.keyDifferentiators}</span>

    {slogan?.fields?.text && (
      <div class="mt-6 text-2xl font-semibold italic leading-snug text-gray-900 dark:text-gray-50">
        <RichText content={slogan.fields.text} />
      </div>
    )}

    {abstract?.fields?.content && (
      <div class="mt-8 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
        <RichText content={abstract.fields.content} />
      </div>
    )}

    <div class="mt-10">
      <p class="text-sm italic text-gray-500 dark:text-gray-400 leading-relaxed max-w-xl pl-6 border-l-[3px] border-primary dark:border-[#5b8ce0]">
        {translations.differentiatorQuote2}
      </p>
    </div>
  </div>
</section>
