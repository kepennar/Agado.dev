---
// TechnicalMastery component - Skills grid with 5 cards

interface Props {
  translations: {
    coreCompetencies: string;
    technicalMasteryTitle: string;
    skillArchitectureTitle: string;
    skillArchitectureDesc: string;
    skillFullstackTitle: string;
    skillFullstackDesc: string;
    skillLeadershipTitle: string;
    skillLeadershipDesc: string;
    skillIntegrationTitle: string;
    skillIntegrationDesc: string;
    skillPerformanceTitle: string;
    skillPerformanceDesc: string;
  };
}

const { translations } = Astro.props;

const skills = [
  {
    title: translations.skillArchitectureTitle,
    desc: translations.skillArchitectureDesc,
    icon: "architecture",
    large: true,
    highlighted: false,
  },
  {
    title: translations.skillFullstackTitle,
    desc: translations.skillFullstackDesc,
    icon: "code",
    large: true,
    highlighted: true,
    tags: ["React", "Vue", "Node.js", "Java", "PostgreSQL"],
  },
  {
    title: translations.skillLeadershipTitle,
    desc: translations.skillLeadershipDesc,
    icon: "people",
    large: false,
    highlighted: false,
  },
  {
    title: translations.skillIntegrationTitle,
    desc: translations.skillIntegrationDesc,
    icon: "puzzle",
    large: false,
    highlighted: false,
  },
  {
    title: translations.skillPerformanceTitle,
    desc: translations.skillPerformanceDesc,
    icon: "speed",
    large: false,
    highlighted: false,
  },
];
---

<section id="services" class="py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <span class="section-label">{translations.coreCompetencies}</span>
    <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-3 mb-10">{translations.technicalMasteryTitle}</h2>

    <div class="skills-grid">
      {skills.map((skill) => (
        <div class:list={[
          "skill-card p-6 border rounded-xl transition-all duration-200 hover:-translate-y-0.5",
          skill.large ? "p-8" : "",
          skill.highlighted
            ? "bg-primary dark:bg-[#1e3a6e] border-primary dark:border-[#2a4a80] text-white hover:shadow-[0_8px_24px_rgba(52,87,160,0.3)] dark:hover:shadow-[0_8px_24px_rgba(52,87,160,0.4)]"
            : "bg-white dark:bg-gray-900 border-gray-200 dark:border-gray-800 hover:shadow-[0_8px_24px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_8px_24px_rgba(0,0,0,0.3)]",
        ]}>
          <div class:list={[
            "mb-4",
            skill.highlighted ? "text-white/80" : "text-primary dark:text-[#8ab4f8]",
          ]}>
            {skill.icon === "architecture" && (
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            )}
            {skill.icon === "code" && (
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            )}
            {skill.icon === "people" && (
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            )}
            {skill.icon === "puzzle" && (
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
              </svg>
            )}
            {skill.icon === "speed" && (
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            )}
          </div>
          <h3 class:list={[
            "text-lg font-bold mb-2",
            skill.highlighted ? "text-white" : "text-gray-900 dark:text-gray-50",
          ]}>{skill.title}</h3>
          <p class:list={[
            "text-sm leading-relaxed m-0",
            skill.highlighted ? "text-white/80" : "text-gray-500 dark:text-gray-400",
          ]}>{skill.desc}</p>
          {skill.tags && (
            <div class="flex flex-wrap gap-2 mt-4">
              {skill.tags.map((tag) => (
                <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-white/20 dark:bg-white/15 text-white font-sans">{tag}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Grid layout: 2 large cards top, 3 smaller bottom using 6-col grid */
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 769px) {
    .skills-grid {
      grid-template-columns: repeat(6, 1fr);
    }

    .skill-card:nth-child(1) {
      grid-column: span 3;
    }

    .skill-card:nth-child(2) {
      grid-column: span 3;
    }

    .skill-card:nth-child(3),
    .skill-card:nth-child(4),
    .skill-card:nth-child(5) {
      grid-column: span 2;
    }
  }
</style>
