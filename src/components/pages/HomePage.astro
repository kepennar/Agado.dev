---
import Experiences from "@/components/Experiences.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import KeyDifferentiators from "@/components/KeyDifferentiators.astro";
import LatestPosts from "@/components/LatestPosts.astro";
import Layout from "@/components/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import TechnicalMastery from "@/components/TechnicalMastery.astro";

import type { Language } from "@/i18n/i18n.model";
import {
  getTranslations,
  getContentfulLocaleParam,
  localizedUrl,
} from "@/i18n/i18n.model";
import {
  getAbstract,
  getBlogPosts,
  getExperiences,
  getSlogan,
  getSocials,
} from "@/lib/contentful";

const lang = (Astro.currentLocale || "fr") as Language;
const t = getTranslations(lang);
const locale = getContentfulLocaleParam(lang);

const [slogan, abstract, socials, experiences, blogPosts] = await Promise.all([
  getSlogan(locale),
  getAbstract(locale),
  getSocials(locale),
  getExperiences(locale),
  getBlogPosts(locale),
]);

if (!slogan || !abstract) {
  throw new Error("Required content missing: slogan or abstract");
}
---

<Layout
  title="Agado Dev - Kevin Pennarun"
  description={t.seo.defaultDescription}
  lang={lang}
>
  <div class="min-h-screen pt-16 print:pt-0">
    <div class="fixed w-full top-0 z-50 print:static">
      <Navbar
        currentLanguage={lang}
        translations={{
          brand: t.nav.brand,
          about: t.nav.about,
          expertises: t.nav.expertises,
          experience: t.nav.experience,
          posts: t.nav.posts,
          articles: t.nav.articles,
          toggleDarkMode: t.aria.toggleDarkMode,
          switchToLight: t.aria.switchToLight,
          switchToDark: t.aria.switchToDark,
        }}
      />
    </div>

    <Header
      siteTitle="Kevin Pennarun"
      abstract={abstract}
      socials={socials}
      translations={{
        heroLabel: t.home.heroLabel,
        heroSubtitle: t.home.heroSubtitle,
        seeExperienceBtn: t.home.seeExperienceBtn,
      }}
    />

    <div class="animate-section">
      <KeyDifferentiators
        slogan={slogan}
        abstract={abstract}
        translations={{
          keyDifferentiators: t.home.keyDifferentiators,
          differentiatorQuote2: t.home.differentiatorQuote2,
        }}
      />
    </div>

    <div class="animate-section">
      <TechnicalMastery
        translations={{
          coreCompetencies: t.home.coreCompetencies,
          technicalMasteryTitle: t.home.technicalMasteryTitle,
          skillArchitectureTitle: t.home.skillArchitectureTitle,
          skillArchitectureDesc: t.home.skillArchitectureDesc,
          skillFullstackTitle: t.home.skillFullstackTitle,
          skillFullstackDesc: t.home.skillFullstackDesc,
          skillLeadershipTitle: t.home.skillLeadershipTitle,
          skillLeadershipDesc: t.home.skillLeadershipDesc,
          skillIntegrationTitle: t.home.skillIntegrationTitle,
          skillIntegrationDesc: t.home.skillIntegrationDesc,
          skillPerformanceTitle: t.home.skillPerformanceTitle,
          skillPerformanceDesc: t.home.skillPerformanceDesc,
        }}
      />
    </div>

    <div class="animate-section">
      <Experiences
        experiences={experiences}
        translations={{
          professionalJourney: t.home.professionalJourney,
          timelineTitle: t.home.timelineTitle,
          showMore: t.home.showMore,
        }}
      />
    </div>

    <div class="animate-section">
      <LatestPosts
        posts={blogPosts}
        locale={lang}
        title={t.home.latestPosts}
        sectionLabel={t.home.publishedArticles}
        seeAllText={t.home.seeAllPosts}
        seeAllUrl={localizedUrl("/blog", lang)}
      />
    </div>

    <Footer
      madeWith={t.footer.madeWith}
      by={t.footer.by}
      copyright={t.footer.copyright}
    />
  </div>
</Layout>

<style>
  .animate-section {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }

  .animate-section.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-section {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    var sections = document.querySelectorAll(".animate-section");
    if (!sections.length) return;
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    sections.forEach(function (el) {
      observer.observe(el);
    });
  })();
</script>
